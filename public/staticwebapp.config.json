{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/*.{js,css,png,jpg,svg,ico,woff,woff2,ttf}"]
  },
  "routes": [
    {
      "route": "/api/calil/*",
      "methods": ["GET"]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
